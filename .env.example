# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is git-ignored on purpose.
# On Vercel, set these in Project Settings > Environment Variables instead.

# Which provider to use: groq | openai | ollama | openrouter
LLM_PROVIDER=openrouter

# --- OpenRouter (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# DeepSeek V4 Flash via OpenRouter (OpenAI-compatible). See https://openrouter.ai/models
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Optional ranking headers shown on openrouter.ai leaderboards
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=PortfolioAI

# --- Groq (https://console.groq.com/keys) ---
# GROQ_API_KEY=gsk_...

# --- OpenAI ---
# OPENAI_API_KEY=sk-proj-...

# Optional: override the model for the active provider
# LLM_MODEL=

# --- Rate limiting ---
# Defaults to 2 requests per IP per minute. Tune for a public deployment:
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_SECONDS=60
#
# Durable, cross-instance limiting (STRONGLY recommended for a public site on Vercel):
# create a free Redis at https://upstash.com and paste its REST URL + token here.
# If unset, an in-memory fallback is used (per-instance only — fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- API origin allowlist (CSRF-style guard on the LLM endpoints) ---
# Comma-separated origins permitted to call /api/* (e.g. your production domain).
# Leave blank to allow same-origin requests only (compared against the Host header).
# ALLOWED_ORIGINS=https://your-domain.com
