# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is git-ignored on purpose.
# On Vercel, set these in Project Settings > Environment Variables instead.

# Which provider to use: groq | openai | ollama | openrouter
LLM_PROVIDER=openrouter

# --- OpenRouter (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Use the free auto-router, or pin a specific free model e.g. meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=openrouter/free
# Optional ranking headers shown on openrouter.ai leaderboards
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=PortfolioAI

# --- Groq (https://console.groq.com/keys) ---
# GROQ_API_KEY=gsk_...

# --- OpenAI ---
# OPENAI_API_KEY=sk-proj-...

# Optional: override the model for the active provider
# LLM_MODEL=

# --- Rate limiting (2 requests per IP per minute) ---
# Optional but recommended in production on Vercel so the limit is shared across
# all serverless instances. Create a free Redis at https://upstash.com and copy
# its REST URL + token here. If unset, an in-memory fallback is used (local dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
